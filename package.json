{
  "name": "@agent-assembly/sdk",
  "version": "0.0.0",
  "description": "TypeScript SDK for Agent Assembly",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AI-agent-assembly/node-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/AI-agent-assembly/node-sdk/issues"
  },
  "homepage": "https://github.com/AI-agent-assembly/node-sdk#readme",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm run build:esm && pnpm run build:cjs",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "native:build": "pnpm exec napi build --manifest-path native/aa-ffi-node/Cargo.toml --output-dir native/aa-ffi-node --no-js --dts index.d.ts --js-package-name @agent-assembly/sdk",
    "native:build:release": "pnpm exec napi build --manifest-path native/aa-ffi-node/Cargo.toml --output-dir native/aa-ffi-node --release --platform --no-js --dts index.d.ts --js-package-name @agent-assembly/sdk",
    "native:check-types": "tsc --strict --noEmit native/aa-ffi-node/index.d.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text",
    "build:esm": "tsc -p tsconfig.build.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "dependencies": {
    "@langchain/core": "^0.3.80"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@napi-rs/cli": "3.1.5",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.1.8",
    "blocked-at": "^1.2.0",
    "eslint": "^9.24.0",
    "langchain": "^0.3.27",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "agent-assembly",
    "sdk",
    "typescript",
    "nodejs"
  ],
  "optionalDependencies": {
    "@agent-assembly/linux-x64-gnu": "0.0.0",
    "@agent-assembly/darwin-x64": "0.0.0",
    "@agent-assembly/darwin-arm64": "0.0.0",
    "@agent-assembly/win32-x64-msvc": "0.0.0"
  },
  "files": [
    "dist/",
    "native/aa-ffi-node/*.node",
    "native/aa-ffi-node/index.cjs",
    "native/aa-ffi-node/index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "types": "./dist/types/index.d.ts"
}
