{
  "name": "@agent-assembly/sdk",
  "version": "0.0.0",
  "description": "TypeScript SDK for Agent Assembly",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AI-agent-assembly/node-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/AI-agent-assembly/node-sdk/issues"
  },
  "homepage": "https://github.com/AI-agent-assembly/node-sdk#readme",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.24.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "agent-assembly",
    "sdk",
    "typescript",
    "nodejs"
  ]
}
